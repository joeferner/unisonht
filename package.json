{
  "name": "@unisonht/unisonht",
  "version": "0.0.3",
  "description": "UnisonHT - Unified Home Theatre",
  "main": "target/index.js",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "watch": "nodemon -w target target/index.js",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.js\" \"web/**/*.ts\" \"web/**/*.js\"",
    "lint": "tslint -p tsconfig.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joeferner/unisonht.git"
  },
  "keywords": [
    "home",
    "theatre",
    "raspberry",
    "pi"
  ],
  "author": "Joe Ferner <joe@fernsroth.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/joeferner/unisonht/issues"
  },
  "homepage": "https://github.com/joeferner/unisonht#readme",
  "dependencies": {
    "@babel/standalone": "^7.7.6",
    "axios": "^0.19.0",
    "onsenui": "^2.10.10",
    "react": "^16.12.0",
    "react-dom": "^16.12.0",
    "react-onsenui": "^1.11.2",
    "roku-client": "^3.1.6"
  },
  "devDependencies": {
    "@types/node": "^12.12.17",
    "tslint": "^5.20.1",
    "typescript": "^3.7.3",
    "nodemon": "^2.0.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged && npm run lint"
    }
  },
  "lint-staged": {
    "*": [
      "npm run format",
      "git add"
    ]
  }
}
